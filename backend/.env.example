# ============================================
# 环境变量模板 — director-ai backend
# 使用方法：复制为 .env 并填入真实值
#   cp .env.example .env
# 注意：.env 已被 .gitignore 忽略，切勿提交到仓库
# ============================================

# --- 应用配置 ---
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:5173

# --- M3 连贯模式 ---
# true：资产一致性 + 链式尾帧 + xfade 转场 + 连续旁白（默认）
# false：回退 M2 行为（无资产、并行视频、硬拼接）
COHERENT_MODE=true
# xfade 交叉淡化时长（秒）
XFADE_DURATION=0.4

# --- Agnes AI ---
# AGNES_API_KEY=your_agnes_api_key
AGNES_API_BASE=https://apihub.agnes-ai.com
AGNES_LLM_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0
AGNES_VIDEO_FRAME_RATE=24
AGNES_VIDEO_MAX_FRAMES=441

# --- Provider 选择 ---
LLM_PROVIDER=mock
IMAGE_PROVIDER=mock
VIDEO_PROVIDER=mock
TTS_PROVIDER=mock

# --- TTS（Edge-TTS 免费，无需 Key）---
TTS_VOICE=zh-CN-XiaoxiaoNeural

# --- 本地输出与 FFmpeg ---
OUTPUTS_DIR=outputs
# FFMPEG_FONT_PATH=

# --- 视频并发（M2 模式）---
VIDEO_MAX_CONCURRENCY=2

# --- 数据库与队列 ---
DATABASE_URL=sqlite:///./director_ai.db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- 小说线 LLM（与视频 llm_provider 独立）---
NOVEL_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
ZHIPU_API_KEY=
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash
CHROMA_PERSIST_DIR=./data/chroma
NOVEL_INITIAL_CHAPTERS=3
NOVEL_TARGET_WORDS_MIN=2500
NOVEL_TARGET_WORDS_MAX=3500
