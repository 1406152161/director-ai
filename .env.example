# ============================================
# 环境变量模板 — director-ai
# 使用方法：复制为 .env 并填入真实值
#   cp .env.example .env
# 注意：.env 已被 .gitignore 忽略，切勿提交到仓库
# ============================================

# --- LLM 服务（剧本 / 分镜生成） ---
# LLM_API_KEY=your_llm_api_key
# LLM_BASE_URL=https://api.example.com/v1
# LLM_MODEL=deepseek-chat

# --- 图像生成服务（角色 / 场景 / 关键帧） ---
# IMAGE_API_KEY=your_image_api_key
# IMAGE_BASE_URL=https://api.example.com

# --- 视频生成服务（Image-to-Video / 插帧） ---
# VIDEO_API_KEY=your_video_api_key
# VIDEO_BASE_URL=https://api.example.com

# --- 语音合成（TTS 配音） ---
# TTS_API_KEY=your_tts_api_key
# TTS_REGION=cn-shanghai

# --- 语音识别（ASR 字幕，可选） ---
# ASR_API_KEY=your_asr_api_key

# --- 应用配置 ---
# APP_ENV=development
# APP_PORT=8000
# FRONTEND_URL=http://localhost:5173
